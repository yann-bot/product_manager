<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= title %></title>
<style>
  :root { --bg:#0f172a; --card:#1e293b; --line:#334155; --txt:#e2e8f0; --muted:#94a3b8; --accent:#38bdf8; }
  * { box-sizing: border-box; }
  body { margin:0; background:var(--bg); color:var(--txt); font:14px/1.5 system-ui,-apple-system,Segoe UI,Roboto,sans-serif; }
  header { padding:24px 32px; border-bottom:1px solid var(--line); }
  h1 { margin:0 0 4px; font-size:20px; }
  .sub { color:var(--muted); font-size:13px; }
  .cards { display:flex; gap:16px; flex-wrap:wrap; padding:20px 32px; }
  .card { background:var(--card); border:1px solid var(--line); border-radius:10px; padding:14px 18px; min-width:160px; }
  .card .k { color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.04em; }
  .card .v { font-size:22px; font-weight:600; margin-top:4px; }
  .card .v.accent { color:var(--accent); }
  .wrap { padding:0 32px 40px; }
  table { width:100%; border-collapse:collapse; background:var(--card); border:1px solid var(--line); border-radius:10px; overflow:hidden; }
  thead th { text-align:left; font-size:12px; text-transform:uppercase; letter-spacing:.04em; color:var(--muted); padding:12px 14px; border-bottom:1px solid var(--line); position:sticky; top:0; background:var(--card); }
  tbody td { padding:11px 14px; border-bottom:1px solid var(--line); vertical-align:top; }
  tbody tr:hover { background:#27344b; }
  tbody tr:last-child td { border-bottom:none; }
  .num { text-align:right; white-space:nowrap; font-variant-numeric:tabular-nums; }
  .strong { font-weight:600; }
  .ref { font-family:ui-monospace,SFMono-Regular,Menlo,monospace; color:var(--accent); }
  .muted { color:var(--muted); }
  .empty { text-align:center; color:var(--muted); padding:32px; }
  .tag { display:inline-block; font-size:11px; padding:2px 8px; border-radius:999px; background:#27344b; border:1px solid var(--line); color:var(--txt); white-space:nowrap; }
  .tag + .tag { margin-left:6px; }
  .tag-active { background:rgba(56,189,248,.15); border-color:var(--accent); color:var(--accent); }
  .pagination { display:flex; align-items:center; gap:12px; margin-top:14px; flex-wrap:wrap; }
  .pg-btn { background:var(--card); border:1px solid var(--line); color:var(--txt); border-radius:8px; padding:7px 12px; font-size:13px; cursor:pointer; transition:border-color .15s,color .15s; }
  .pg-btn:hover:not(:disabled) { border-color:var(--accent); color:var(--accent); }
  .pg-btn:disabled { opacity:.4; cursor:default; }
  .pg-info { color:var(--muted); font-size:13px; }
  input.filter { width:100%; max-width:360px; margin:0 0 14px; padding:9px 12px; background:var(--card); border:1px solid var(--line); border-radius:8px; color:var(--txt); font-size:14px; }
  .nav { display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-bottom:18px; }
  .nav a { color:var(--txt); text-decoration:none; border:1px solid var(--line); border-radius:8px; padding:7px 14px; font-size:13px; background:var(--card); transition:border-color .15s,color .15s; }
  .nav a:hover { border-color:var(--accent); }
  .nav a.active { border-color:var(--accent); color:var(--accent); }
  .nav .brand { font-weight:600; border:none; background:none; padding-left:0; padding-right:14px; font-size:15px; }
</style>
</head>
<body>
  <header>
    <nav class="nav">
      <a class="brand" href="/">📊 Dashboard</a>
      <a href="/easysell-orders/view" class="<%= active === 'easysell-orders' ? 'active' : '' %>">Commandes EasySell</a>
    </nav>
    <h1><%= title %></h1>
    <% if (subtitle) { %><div class="sub"><%= subtitle %></div><% } %>
  </header>
  <%- body %>
  <script>
    // Contrôleur de table générique : filtre + pagination côté client.
    // - <input data-filter="#tableId">  : filtre plein texte sur les lignes.
    // - <table data-page-size="N">      : pagine par tranches de N lignes.
    // Les deux se coordonnent : le filtre porte sur tout le jeu de données,
    // la pagination ne pagine que les lignes qui matchent le filtre.

    function setupTable(table) {
      const pageSize = parseInt(table.dataset.pageSize || '0', 10);
      // Lignes réelles uniquement (on exclut la ligne "vide" éventuelle).
      const rows = Array.from(table.querySelectorAll('tbody tr'))
        .filter((r) => !r.querySelector('.empty'));
      const filterInput = table.id
        ? document.querySelector('input[data-filter="#' + table.id + '"]')
        : null;

      let term = '';
      let page = 1;

      let controls = null;
      if (pageSize > 0 && rows.length > 0) {
        controls = document.createElement('div');
        controls.className = 'pagination';
        table.parentNode.insertBefore(controls, table.nextSibling);
      }

      function mkBtn(label, onClick, disabled) {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'pg-btn';
        b.textContent = label;
        b.disabled = disabled;
        if (!disabled) b.addEventListener('click', onClick);
        return b;
      }

      function render() {
        const matched = term
          ? rows.filter((r) => r.textContent.toLowerCase().includes(term))
          : rows;
        const usePages = pageSize > 0;
        const totalPages = usePages ? Math.max(1, Math.ceil(matched.length / pageSize)) : 1;
        if (page > totalPages) page = totalPages;

        for (const r of rows) r.style.display = 'none';
        const start = usePages ? (page - 1) * pageSize : 0;
        const end = usePages ? start + pageSize : matched.length;
        for (const r of matched.slice(start, end)) r.style.display = '';

        if (controls) {
          controls.innerHTML = '';
          const info = document.createElement('span');
          info.className = 'pg-info';
          const n = matched.length;
          info.textContent = n + ' résultat' + (n > 1 ? 's' : '') + ' · page ' + page + '/' + totalPages;
          controls.append(
            mkBtn('‹ Préc.', () => { page--; render(); }, page <= 1),
            mkBtn('Suiv. ›', () => { page++; render(); }, page >= totalPages),
            info,
          );
        }
      }

      if (filterInput) {
        filterInput.addEventListener('input', () => {
          term = filterInput.value.toLowerCase();
          page = 1;
          render();
        });
      }
      render();
    }

    // Tables paginées, et tables filtrées-seules (sans pagination).
    const handled = new Set();
    for (const table of document.querySelectorAll('table[data-page-size]')) {
      handled.add(table);
      setupTable(table);
    }
    for (const input of document.querySelectorAll('input[data-filter]')) {
      const table = document.querySelector(input.getAttribute('data-filter'));
      if (table && !handled.has(table)) setupTable(table);
    }
  </script>
</body>
</html>

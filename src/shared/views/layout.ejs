<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= title %></title>
<style>
  :root {
    --bg:#e7ecf7; --card:#ffffff; --panel-2:#f1f4fa; --line:#e7ebf2;
    --txt:#1b1d29; --muted:#7a808f; --accent:#3b5bdb; --accent-2:#5c7cfa;
    --accent-soft:#e8edff; --pos:#2f9e5b; --pos-soft:#e7f4ec;
    --shadow:0 1px 3px rgba(20,25,45,.07), 0 1px 2px rgba(20,25,45,.05);
    --sidebar-1:#18181d; --sidebar-2:#0d0d10; --sidebar-txt:#9aa0b0;
    /* Teintes pastel des cartes "assets" (maquette Coinview). */
    --pastel-lav:#ece9fb; --pastel-mint:#e6f4ec; --pastel-cream:#faf3e3;
  }
  * { box-sizing: border-box; }
  body { margin:0; display:flex; min-height:100vh; background:var(--bg); color:var(--txt); font:14px/1.5 system-ui,-apple-system,Segoe UI,Roboto,sans-serif; }

  /* ---- Sidebar ---- */
  .sidebar { width:232px; flex:0 0 232px; background:linear-gradient(180deg,var(--sidebar-1),var(--sidebar-2)); color:var(--sidebar-txt); display:flex; flex-direction:column; padding:20px 14px; position:sticky; top:0; align-self:flex-start; height:100vh; overflow:auto; }
  .brand { display:flex; align-items:center; gap:11px; padding:4px 8px 18px; }
  .brand .logo { width:40px; height:40px; border-radius:12px; background:#f4efe2; display:flex; align-items:center; justify-content:center; color:#1b1d29; }
  .brand .bt { font-weight:700; font-size:15px; color:#fff; }
  .brand .bs { font-size:11px; opacity:.78; }
  .side-nav { display:flex; flex-direction:column; gap:3px; margin-top:6px; flex:1; }
  .side-nav a.nav-pin { margin-top:auto; }
  .side-nav a { display:flex; align-items:center; gap:11px; padding:10px 12px; border-radius:9px; color:var(--sidebar-txt); text-decoration:none; font-size:13.5px; transition:background .15s,color .15s; }
  .side-nav a:hover { background:rgba(255,255,255,.09); color:#fff; }
  .side-nav a.active { background:rgba(255,255,255,.17); color:#fff; font-weight:600; }
  .side-nav .ic { width:20px; flex:0 0 20px; display:inline-flex; align-items:center; justify-content:center; }
  /* Groupes repliables (natifs <details>, sans JS). */
  .side-nav details.group { margin:0; }
  .side-nav details.group > summary { display:flex; align-items:center; gap:11px; padding:10px 12px; border-radius:9px; color:var(--sidebar-txt); font-size:13.5px; cursor:pointer; list-style:none; user-select:none; transition:background .15s,color .15s; }
  .side-nav details.group > summary::-webkit-details-marker { display:none; }
  .side-nav details.group > summary:hover { background:rgba(255,255,255,.09); color:#fff; }
  .side-nav details.group[open] > summary { color:#fff; }
  .side-nav details.group > summary .chev { margin-left:auto; font-size:10px; opacity:.7; transition:transform .15s; }
  .side-nav details.group[open] > summary .chev { transform:rotate(90deg); }
  .side-nav details.group .sub { display:flex; flex-direction:column; gap:2px; margin:2px 0 4px 21px; padding-left:11px; border-left:1px solid rgba(255,255,255,.12); }
  .side-nav details.group .sub a { padding:8px 12px; font-size:13px; }
  .side-foot { margin-top:auto; padding:14px 12px 2px; font-size:11px; opacity:.72; border-top:1px solid rgba(255,255,255,.1); }

  /* ---- App shell ---- */
  .app { flex:1; min-width:0; display:flex; flex-direction:column; }
  .topbar { display:flex; align-items:center; justify-content:space-between; gap:16px; padding:15px 26px; background:var(--card); border-bottom:1px solid var(--line); position:sticky; top:0; z-index:5; }
  .topbar h1 { margin:0; font-size:18px; }
  .topbar .sub { color:var(--muted); font-size:12.5px; }
  .topbar-actions { display:flex; align-items:center; gap:12px; }
  .searchbox { display:flex; align-items:center; gap:8px; background:var(--panel-2); border:1px solid var(--line); border-radius:999px; padding:7px 14px; color:var(--muted); font-size:13px; min-width:230px; }
  .searchbox input { border:none; background:none; outline:none; color:var(--txt); font:inherit; width:100%; }
  .icon-btn { width:36px; height:36px; border-radius:10px; background:var(--panel-2); border:1px solid var(--line); display:flex; align-items:center; justify-content:center; font-size:15px; color:var(--muted); }

  /* ---- Dashboard ---- */
  .dash { padding:22px 26px 40px; }
  .section-h { font-size:12px; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); font-weight:600; margin:8px 0 12px; }
  .kpis { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:24px; }
  .kpi { background:var(--card); border:1px solid var(--line); border-radius:14px; box-shadow:var(--shadow); padding:16px 18px; display:flex; align-items:center; gap:14px; }
  .kpi-ic { width:46px; height:46px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:22px; flex:0 0 46px; }
  .kpi-blue { background:#e3eef3; } .kpi-green { background:#e3f1ea; } .kpi-violet { background:#ebe9f5; } .kpi-amber { background:#f8efdc; }
  .kpi-v { font-size:24px; font-weight:700; line-height:1.1; }
  .kpi-l { font-size:12.5px; color:var(--muted); margin-top:2px; }
  .panels { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; }
  .panel { background:var(--card); border:1px solid var(--line); border-radius:14px; box-shadow:var(--shadow); padding:18px 20px; }
  .panel-wide { grid-column:1 / -1; }
  .panel-h { font-size:14px; font-weight:600; margin-bottom:14px; display:flex; align-items:center; justify-content:space-between; gap:10px; }
  .panel-tag { font-size:11px; font-weight:500; color:var(--muted); background:var(--panel-2); border:1px solid var(--line); border-radius:999px; padding:2px 9px; }
  .panel-empty { padding:26px 0; text-align:center; }
  .donut-row { display:flex; align-items:center; gap:24px; flex-wrap:wrap; }
  .legend { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:13px; min-width:210px; }
  .legend li { display:flex; align-items:center; gap:9px; font-size:13px; }
  .legend li b { margin-left:auto; font-variant-numeric:tabular-nums; }
  .legend li .muted { min-width:48px; text-align:right; }
  .legend .dot { width:11px; height:11px; border-radius:3px; flex:0 0 11px; }
  .source-panel { margin-top:8px; }

  /* ===== Vue d'ensemble « Coinview » (page d'accueil restylée) ===== */
  .ov-title { font-size:22px; font-weight:700; margin:2px 0 18px; }
  .ov-top { display:grid; grid-template-columns:1.1fr 1fr; gap:18px; margin-bottom:18px; }

  /* Carte « Portfolio » -> Chiffre d'affaires + courbe. */
  .portfolio { background:linear-gradient(150deg,#eef1fc,#f5f3fb); border:1px solid var(--line); border-radius:18px; padding:20px 22px; box-shadow:var(--shadow); }
  .pf-h { font-size:13px; color:var(--muted); font-weight:600; }
  .pf-bal { font-size:30px; font-weight:700; letter-spacing:-.01em; margin-top:6px; display:flex; align-items:baseline; gap:10px; }
  .pf-pill { font-size:12px; font-weight:600; color:var(--pos); background:var(--pos-soft); border-radius:999px; padding:3px 10px; }
  .pf-sub { font-size:12.5px; color:var(--muted); margin-top:2px; }
  .pf-chart { margin:6px -6px 4px; }
  .pf-chart svg { width:100%; height:auto; }
  .pf-range { display:flex; gap:6px; flex-wrap:wrap; margin-top:6px; }
  .pf-range span { font-size:11.5px; color:var(--muted); border-radius:999px; padding:4px 11px; cursor:default; }
  .pf-range span.on { background:#1b1d29; color:#fff; font-weight:600; }

  /* « Your Assets » -> cartes KPI pastel. */
  .assets { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
  .asset { border-radius:18px; padding:16px 16px 18px; display:flex; flex-direction:column; min-height:148px; box-shadow:var(--shadow); }
  .asset.lav { background:var(--pastel-lav); } .asset.mint { background:var(--pastel-mint); } .asset.cream { background:var(--pastel-cream); }
  .asset-v { font-size:21px; font-weight:700; line-height:1.1; }
  .asset-l { font-size:12px; color:#5a5f6e; margin-top:3px; }
  .asset-foot { margin-top:auto; display:flex; align-items:center; justify-content:space-between; gap:8px; }
  .asset-ic { width:34px; height:34px; border-radius:50%; background:#1b1d29; color:#fff; display:flex; align-items:center; justify-content:center; font-size:16px; }
  .asset-delta { font-size:12px; font-weight:600; color:var(--pos); }
  .asset-delta.amber { color:#c98a16; }
  .asset-delta.muted { color:var(--muted); }

  /* Carte « Market » -> table top produits. */
  .market { background:var(--card); border:1px solid var(--line); border-radius:18px; box-shadow:var(--shadow); padding:18px 20px; }
  .mk-h { font-size:15px; font-weight:700; margin-bottom:6px; }
  .mk-table { width:100%; border-collapse:collapse; background:none; border:none; box-shadow:none; border-radius:0; }
  .mk-table th { text-align:left; font-size:11px; text-transform:uppercase; letter-spacing:.04em; color:var(--muted); font-weight:600; padding:8px 6px; border-bottom:1px solid var(--line); background:none; position:static; }
  .mk-table td { padding:11px 6px; border-bottom:1px solid var(--line); vertical-align:middle; }
  .mk-table tr:last-child td { border-bottom:none; }
  .mk-name { display:flex; align-items:center; gap:11px; }
  .mk-badge { width:32px; height:32px; border-radius:9px; background:#1b1d29; color:#fff; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; flex:0 0 32px; }
  .mk-name b { font-weight:600; }
  .mk-name small { display:block; color:var(--muted); font-size:11px; text-transform:uppercase; letter-spacing:.03em; }
  .mk-pos { color:var(--pos); font-weight:600; }

  @media (max-width:1000px) {
    .kpis { grid-template-columns:repeat(2,1fr); }
    .panels { grid-template-columns:1fr; }
    .ov-top { grid-template-columns:1fr; }
    .assets { grid-template-columns:repeat(3,1fr); }
  }
  @media (max-width:640px) {
    .sidebar { display:none; }
    .searchbox { display:none; }
    .assets { grid-template-columns:1fr; }
  }

  /* ---- Composants partagés (re-thémés clair) ---- */
  .cards { display:flex; gap:16px; flex-wrap:wrap; padding:20px 28px; }
  .card { background:var(--card); border:1px solid var(--line); border-radius:12px; box-shadow:var(--shadow); padding:14px 18px; min-width:160px; }
  .card .k { color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.04em; }
  .card .v { font-size:22px; font-weight:600; margin-top:4px; }
  .card .v.accent { color:var(--accent); }
  .wrap { padding:20px 28px 40px; }
  table { width:100%; border-collapse:collapse; background:var(--card); border:1px solid var(--line); border-radius:12px; overflow:hidden; box-shadow:var(--shadow); }
  thead th { text-align:left; font-size:12px; text-transform:uppercase; letter-spacing:.04em; color:var(--muted); padding:12px 14px; border-bottom:1px solid var(--line); position:sticky; top:0; background:var(--card); }
  tbody td { padding:11px 14px; border-bottom:1px solid var(--line); vertical-align:top; }
  tbody tr:hover { background:var(--panel-2); }
  tbody tr:last-child td { border-bottom:none; }
  .num { text-align:right; white-space:nowrap; font-variant-numeric:tabular-nums; }
  .strong { font-weight:600; }
  .ref { font-family:ui-monospace,SFMono-Regular,Menlo,monospace; color:var(--accent); }
  .muted { color:var(--muted); }
  .empty { text-align:center; color:var(--muted); padding:32px; }
  .tag { display:inline-block; font-size:11px; padding:2px 8px; border-radius:999px; background:var(--panel-2); border:1px solid var(--line); color:var(--txt); white-space:nowrap; }
  .tag + .tag { margin-left:6px; }
  .tag-active { background:var(--accent-soft); border-color:var(--accent); color:var(--accent); }
  .pagination { display:flex; align-items:center; gap:12px; margin-top:14px; flex-wrap:wrap; }
  .pg-btn { background:var(--card); border:1px solid var(--line); color:var(--txt); border-radius:8px; padding:7px 12px; font-size:13px; cursor:pointer; transition:border-color .15s,color .15s; }
  .pg-btn:hover:not(:disabled) { border-color:var(--accent); color:var(--accent); }
  .pg-btn:disabled { opacity:.4; cursor:default; }
  .pg-info { color:var(--muted); font-size:13px; }
  input.filter { width:100%; max-width:360px; margin:0 0 14px; padding:9px 12px; background:var(--card); border:1px solid var(--line); border-radius:8px; color:var(--txt); font-size:14px; }
  input.filter:focus { outline:none; border-color:var(--accent); }
  .nav { display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-bottom:18px; }
  .nav a { color:var(--txt); text-decoration:none; border:1px solid var(--line); border-radius:8px; padding:7px 14px; font-size:13px; background:var(--card); transition:border-color .15s,color .15s; }
  .nav a:hover { border-color:var(--accent); }
  .nav a.active { border-color:var(--accent); color:var(--accent); }
  .nav .brand { font-weight:600; border:none; background:none; padding-left:0; padding-right:14px; font-size:15px; }
  .toolbar { display:flex; gap:12px; align-items:center; justify-content:space-between; flex-wrap:wrap; margin-bottom:14px; }
  .toolbar .nav { margin-bottom:0; }
  /* Barre de filtres par dates : préréglages + mois précis + intervalle. */
  .datebar { display:flex; gap:12px 20px; align-items:center; flex-wrap:wrap; margin-bottom:10px; }
  .datebar .nav { margin-bottom:0; }
  .datefilter { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
  .datefilter label { display:flex; align-items:center; gap:6px; font-size:13px; color:var(--muted); }
  .datefilter input[type=month], .datefilter input[type=date] { padding:7px 10px; background:var(--card); border:1px solid var(--line); border-radius:8px; color:var(--txt); font:inherit; font-size:13px; }
  .datefilter input:focus { outline:none; border-color:var(--accent); }
  .datebar-label { font-size:12.5px; margin-bottom:16px; }
  a.link { color:var(--accent); text-decoration:none; }
  a.link:hover { text-decoration:underline; }
  .btn { display:inline-block; border:1px solid var(--line); background:var(--card); color:var(--txt); border-radius:8px; padding:8px 14px; font-size:13px; text-decoration:none; cursor:pointer; transition:border-color .15s,color .15s,background .15s; }
  .btn:hover { border-color:var(--accent); color:var(--accent); }
  .btn-primary { border-color:var(--accent); background:var(--accent); color:#fff; }
  .btn-primary:hover { background:#356a80; border-color:#356a80; color:#fff; }
  .btn-danger { border-color:#e06a6a; color:#c0504f; }
  .btn-danger:hover { border-color:#c0504f; color:#a23e3d; }
  .form { background:var(--card); border:1px solid var(--line); border-radius:12px; box-shadow:var(--shadow); padding:22px 24px; max-width:520px; }
  .field { margin-bottom:16px; display:flex; flex-direction:column; gap:6px; }
  .field label { font-size:12px; text-transform:uppercase; letter-spacing:.04em; color:var(--muted); }
  .field input, .field textarea, .field select { width:100%; padding:9px 12px; background:var(--card); border:1px solid var(--line); border-radius:8px; color:var(--txt); font:inherit; }
  .field input:focus, .field textarea:focus, .field select:focus { outline:none; border-color:var(--accent); }
  .field textarea { resize:vertical; }
  .actions { display:flex; gap:12px; align-items:center; margin-top:18px; }
  .actions form { margin:0; }
  .alert { background:#fdecec; border:1px solid #e06a6a; color:#b5413f; border-radius:8px; padding:10px 14px; margin-bottom:18px; font-size:13px; }
  .alert-ok { background:#e3f1ea; border-color:#34a853; color:#1f7a4d; }
  .alert-note { background:#fff6e6; border-color:#e0a96a; color:#9a6a1f; }
  .detail { background:var(--card); border:1px solid var(--line); border-radius:12px; box-shadow:var(--shadow); padding:8px 24px; max-width:640px; }
  .detail .row { display:flex; gap:16px; padding:12px 0; border-bottom:1px solid var(--line); }
  .detail .row:last-child { border-bottom:none; }
  .detail .lbl { flex:0 0 140px; color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.04em; padding-top:2px; }
  .detail .val { flex:1; }
  h1 { margin:0 0 4px; font-size:20px; }
  .sub { color:var(--muted); font-size:13px; }
</style>
</head>
<body>
  <%- sidebar %>

  <div class="app">
    <%- topbar %>
    <%- body %>
  </div>

  <script>
    // Contrôleur de table générique : filtre + pagination côté client.
    // - <input data-filter="#tableId">  : filtre plein texte sur les lignes.
    // - <table data-page-size="N">      : pagine par tranches de N lignes.
    // Les deux se coordonnent : le filtre porte sur tout le jeu de données,
    // la pagination ne pagine que les lignes qui matchent le filtre.

    function setupTable(table) {
      const pageSize = parseInt(table.dataset.pageSize || '0', 10);
      // Lignes réelles uniquement (on exclut la ligne "vide" éventuelle).
      const rows = Array.from(table.querySelectorAll('tbody tr'))
        .filter((r) => !r.querySelector('.empty'));
      const filterInput = table.id
        ? document.querySelector('input[data-filter="#' + table.id + '"]')
        : null;

      let term = '';
      let page = 1;

      let controls = null;
      if (pageSize > 0 && rows.length > 0) {
        controls = document.createElement('div');
        controls.className = 'pagination';
        table.parentNode.insertBefore(controls, table.nextSibling);
      }

      function mkBtn(label, onClick, disabled) {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'pg-btn';
        b.textContent = label;
        b.disabled = disabled;
        if (!disabled) b.addEventListener('click', onClick);
        return b;
      }

      function render() {
        const matched = term
          ? rows.filter((r) => r.textContent.toLowerCase().includes(term))
          : rows;
        const usePages = pageSize > 0;
        const totalPages = usePages ? Math.max(1, Math.ceil(matched.length / pageSize)) : 1;
        if (page > totalPages) page = totalPages;

        for (const r of rows) r.style.display = 'none';
        const start = usePages ? (page - 1) * pageSize : 0;
        const end = usePages ? start + pageSize : matched.length;
        for (const r of matched.slice(start, end)) r.style.display = '';

        if (controls) {
          controls.innerHTML = '';
          const info = document.createElement('span');
          info.className = 'pg-info';
          const n = matched.length;
          info.textContent = n + ' résultat' + (n > 1 ? 's' : '') + ' · page ' + page + '/' + totalPages;
          controls.append(
            mkBtn('‹ Préc.', () => { page--; render(); }, page <= 1),
            mkBtn('Suiv. ›', () => { page++; render(); }, page >= totalPages),
            info,
          );
        }
      }

      if (filterInput) {
        filterInput.addEventListener('input', () => {
          term = filterInput.value.toLowerCase();
          page = 1;
          render();
        });
      }
      render();
    }

    // Tables paginées, et tables filtrées-seules (sans pagination).
    const handled = new Set();
    for (const table of document.querySelectorAll('table[data-page-size]')) {
      handled.add(table);
      setupTable(table);
    }
    for (const input of document.querySelectorAll('input[data-filter]')) {
      const table = document.querySelector(input.getAttribute('data-filter'));
      if (table && !handled.has(table)) setupTable(table);
    }
  </script>
</body>
</html>
